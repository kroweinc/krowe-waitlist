    {
      "source": "/api/attachments",
      "destination": "https://kroweportal.vercel.app/api/attachments"
    },
    {
      "source": "/api/audit-log",
      "destination": "https://kroweportal.vercel.app/api/audit-log"
    },
    {
      "source": "/api/build-prompts",
      "destination": "https://kroweportal.vercel.app/api/build-prompts"
    },
    {
      "source": "/api/subtasks",
      "destination": "https://kroweportal.vercel.app/api/subtasks"
    },
    {
      "source": "/api/task-commits",
      "destination": "https://kroweportal.vercel.app/api/task-commits"
    },
    {
      "source": "/KroweIcon.png",
      "destination": "https://kroweportal.vercel.app/KroweIcon.png"
    },
    {
      "source": "/images/:path*",
      "destination": "https://kroweportal.vercel.app/images/:path*"

{
  "rewrites": [
    { "source": "/admin", "destination": "https://krowe-internal.vercel.app/admin" },
    { "source": "/admin/:path*", "destination": "https://krowe-internal.vercel.app/admin/:path*" },

    { "source": "/signup", "destination": "https://krowe-portal.vercel.app/signup" },
    { "source": "/login", "destination": "https://krowe-portal.vercel.app/login" },
    { "source": "/reset-password", "destination": "https://krowe-portal.vercel.app/reset-password" },
    { "source": "/auth/:path*", "destination": "https://krowe-portal.vercel.app/auth/:path*" },
    { "source": "/onboarding", "destination": "https://krowe-portal.vercel.app/onboarding" },
    { "source": "/onboarding/:path*", "destination": "https://krowe-portal.vercel.app/onboarding/:path*" },
    { "source": "/portal", "destination": "https://krowe-portal.vercel.app/portal" },
    { "source": "/portal/:path*", "destination": "https://krowe-portal.vercel.app/portal/:path*" },
    { "source": "/b", "destination": "https://krowe-portal.vercel.app/b" },
    { "source": "/b/:path*", "destination": "https://krowe-portal.vercel.app/b/:path*" },
    { "source": "/o", "destination": "https://krowe-portal.vercel.app/o" },
    { "source": "/o/:path*", "destination": "https://krowe-portal.vercel.app/o/:path*" },
    { "source": "/p/:path*", "destination": "https://krowe-portal.vercel.app/p/:path*" },
    { "source": "/join/:path*", "destination": "https://krowe-portal.vercel.app/join/:path*" },
    { "source": "/contract/:path*", "destination": "https://krowe-portal.vercel.app/contract/:path*" },
    { "source": "/prd/:path*", "destination": "https://krowe-portal.vercel.app/prd/:path*" },
    { "source": "/quotes/:path*", "destination": "https://krowe-portal.vercel.app/quotes/:path*" },
    { "source": "/api/:path*", "destination": "https://krowe-portal.vercel.app/api/:path*" },

    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
